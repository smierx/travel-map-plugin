{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES6",
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strict": true,
        "lib": ["ES6", "DOM"],
        "allowJs": true
    },
    "include": ["**/*.ts"]
}
